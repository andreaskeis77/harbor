HARBOR_ENVIRONMENT=dev
HARBOR_LOG_LEVEL=INFO
HARBOR_HOST=127.0.0.1
HARBOR_PORT=8000
HARBOR_RELOAD=true

# Note: on the VPS use HARBOR_PORT=8100 (port 8000 is reserved for Capsule
# on the shared host). Always bind to 127.0.0.1 on the VPS — public reach
# is not wired; operator access is via Tailscale only.

# SQLAlchemy URL (SQLite is the v0.3.0-alpha default).
# Local dev default (if unset, Harbor writes to ./var/harbor_dev.db):
# HARBOR_SQLALCHEMY_DATABASE_URL=sqlite+pysqlite:///./var/harbor_dev.db
# VPS production:
# HARBOR_SQLALCHEMY_DATABASE_URL=sqlite+pysqlite:///C:/Harbor/var/harbor.db
#
# Deferred alternative — Postgres (not used for v0.3.0-alpha; revisit when
# multi-user or concurrent writers are on the table):
# HARBOR_POSTGRES_HOST=127.0.0.1
# HARBOR_POSTGRES_PORT=5432
# HARBOR_POSTGRES_DB=harbor
# HARBOR_POSTGRES_USER=harbor
# HARBOR_POSTGRES_PASSWORD=change_me
# HARBOR_POSTGRES_ECHO=false
# HARBOR_POSTGRES_POOL_PRE_PING=true

# OpenAI integration.
# Obtain a key at https://platform.openai.com/api-keys.
# Use a separate key per environment (dev vs. VPS) so rotation is surgical.
# Set a monthly spend cap in the OpenAI billing portal as the real safety net.
# HARBOR_OPENAI_API_KEY=sk-...
# HARBOR_OPENAI_MODEL=gpt-5
# HARBOR_OPENAI_BASE_URL=
# HARBOR_OPENAI_TIMEOUT_SECONDS=30.0

# Embedded scheduler (optional): when true, the app runs an in-process
# asyncio loop that calls POST /scheduler/tick on the interval below.
# Leave OFF in dev; enable on the VPS deployment if you don't want to
# wire an external cron/task-scheduler to hit /scheduler/tick.
# HARBOR_SCHEDULER_EMBEDDED=false
# HARBOR_SCHEDULER_EMBEDDED_INTERVAL_SECONDS=60
