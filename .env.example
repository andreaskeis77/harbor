HARBOR_ENVIRONMENT=dev
HARBOR_LOG_LEVEL=INFO
HARBOR_HOST=127.0.0.1
HARBOR_PORT=8000
HARBOR_RELOAD=true

# Optional explicit SQLAlchemy URL.
# For local proof you can temporarily set a sqlite URL, for example:
# HARBOR_SQLALCHEMY_DATABASE_URL=sqlite+pysqlite:///./var/harbor_dev.db
#
# Preferred later production/runtime posture:
# HARBOR_POSTGRES_HOST=127.0.0.1
# HARBOR_POSTGRES_PORT=5432
# HARBOR_POSTGRES_DB=harbor
# HARBOR_POSTGRES_USER=harbor
# HARBOR_POSTGRES_PASSWORD=change_me
#
# Optional:
# HARBOR_POSTGRES_ECHO=false
# HARBOR_POSTGRES_POOL_PRE_PING=true

# OpenAI integration.
# Obtain a key at https://platform.openai.com/api-keys.
# Use a separate key per environment (dev vs. VPS) so rotation is surgical.
# Set a monthly spend cap in the OpenAI billing portal as the real safety net.
# HARBOR_OPENAI_API_KEY=sk-...
# HARBOR_OPENAI_MODEL=gpt-5
# HARBOR_OPENAI_BASE_URL=
# HARBOR_OPENAI_TIMEOUT_SECONDS=30.0
