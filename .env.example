# Harbor runtime
HARBOR_ENVIRONMENT=dev
HARBOR_LOG_LEVEL=INFO
HARBOR_HOST=127.0.0.1
HARBOR_PORT=8000
HARBOR_RELOAD=true

# Harbor storage roots
HARBOR_DATA_ROOT=data
HARBOR_ARTIFACT_ROOT=data/artifacts
HARBOR_VAR_ROOT=var
HARBOR_LOG_ROOT=var/logs
HARBOR_REPORT_ROOT=var/reports

# Postgres baseline
HARBOR_POSTGRES_HOST=127.0.0.1
HARBOR_POSTGRES_PORT=5432
HARBOR_POSTGRES_DB=harbor
HARBOR_POSTGRES_USER=harbor
HARBOR_POSTGRES_PASSWORD=change-me
HARBOR_POSTGRES_ECHO=false
HARBOR_POSTGRES_POOL_PRE_PING=true
